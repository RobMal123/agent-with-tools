# ── Python ─────────────────────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.Python

# ── Secrets ────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Generated / personal data  (directories kept via .gitkeep) ────────────────
chats/*.json
transcriptions/*.md
audio_in/*
!audio_in/.gitkeep
reports/*.md

# ── Memory & vector store ───────────────────────────────────────────────────────
memory.json
chroma_db/

# ── Knowledge base (keep folder skeletons, ignore content) ─────────────────────
knowledge/meetings/*
!knowledge/meetings/.gitkeep
knowledge/ideas/*
!knowledge/ideas/.gitkeep
knowledge/projects/*
!knowledge/projects/.gitkeep
knowledge/reports/*
!knowledge/reports/.gitkeep
knowledge/improvements/*
!knowledge/improvements/.gitkeep
knowledge/videos/*
!knowledge/videos/.gitkeep

# ── Sandboxed REPL workspace ────────────────────────────────────────────────────
workspace/*
!workspace/.gitkeep

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDEs ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

.pytest_cache/

todo/*.md
notes
DEVLOG.md

AGENTS.md
