# Copy this to .env and fill in your keys
# Never commit .env to git!

BRAVE_SEARCH_API_KEY=BSA...

# Security: the python_repl tool executes arbitrary Python IN-PROCESS (no sandbox)
# and is DISABLED by default. Enable it ONLY in a trusted, local-only setup.
# ENABLE_CODE_EXECUTION=true

# Security: shared-secret token for the HTTP API. When set, every request (except /health)
# must send it as "Authorization: Bearer <token>" — the UI reads VITE_API_TOKEN. Leave unset
# for localhost-only use; REQUIRED before exposing the server beyond localhost.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# API_TOKEN=

# Optional: primary Ollama model for reasoning + tool calls (must support tools and be
# available locally). Default: gemma4:e4b — chosen over llama3.2, which mis-fires tool
# calls (e.g. deletes a memory when asked to recall it).
# AGENT_MODEL=gemma4:e4b

# Optional: override if Ollama runs on a non-default host/port
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: Whisper model size for transcription (tiny/base/small/medium/large-v3)
# Larger = more accurate but slower and more RAM. Default: small (~970 MB download)
# WHISPER_MODEL=small

# Optional: Ollama model used for document embeddings (semantic search / RAG)
# Must be pulled first:  ollama pull nomic-embed-text
# EMBED_MODEL=nomic-embed-text

# Optional: dedicated vision model for image turns.
# The main tool-calling model often can't process images (llama3.2 is text-only),
# so messages with an attached image are routed to this model instead.
# Must be pulled first:  ollama pull gemma3:4b   (gemma3 has working vision in Ollama)
# VISION_MODEL=gemma3:4b

# ── Video understanding (process_video tool) ────────────────────────────────────
# Turns a YouTube/TikTok/X URL into a timestamp-aligned SPOKEN+VISUAL timeline in
# knowledge/videos/. Needs ffmpeg on PATH + pip deps (yt-dlp, torch, transformers).
# All optional — defaults shown:
# VIDEO_SCENE_THRESHOLD=0.08   # ffmpeg scene score (luma diff) to keep a keyframe;
#                              # raise toward 0.4 for hard-cuts-only / fewer frames
# VIDEO_MAX_FRAMES=40          # cap on keyframes per video (each = one Moondream call)
# VIDEO_FRAME_MAX_GAP=60       # seconds of static video before an anchor frame is taken
# VIDEO_MAX_DURATION=3600      # refuse videos longer than this many seconds
# MOONDREAM_MODEL=vikhyatk/moondream2          # or moondream/moondream3-preview (more VRAM)
# MOONDREAM_REVISION=2025-06-21                # pinned — Moondream updates `main` often

# Optional: connect an Obsidian vault. When set, the agent reads + semantically
# searches the WHOLE vault and writes its own notes (frontmatter + [[wikilinks]])
# into the OBSIDIAN_AI_SUBDIR folder inside it. Leave unset to use the in-project
# knowledge/ folder. After connecting, run:  python index_vault.py
# OBSIDIAN_VAULT=C:\Users\you\Documents\Obsidian Vault
# OBSIDIAN_AI_SUBDIR=AI Assistant

# LangSmith tracing — get a free key at https://smith.langchain.com
# When enabled, every agent.invoke() call is traced in the LangSmith UI.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=ai-research-agent
