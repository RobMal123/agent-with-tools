# Copy this to .env and fill in your keys
# Never commit .env to git!

BRAVE_SEARCH_API_KEY=BSA...

# Optional: override if Ollama runs on a non-default host/port
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: Whisper model size for transcription (tiny/base/small/medium/large-v3)
# Larger = more accurate but slower and more RAM. Default: small (~970 MB download)
# WHISPER_MODEL=small
